{
  "name": "rzd-energy-calculator",
  "version": "0.3.0",
  "description": "Калькулятор норм расхода электроэнергии и топлива в грузовом движении на тягу поездов",
  "main": "scripts/calculator.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint scripts/*.js tests/*.js",
    "lint:fix": "eslint scripts/*.js tests/*.js --fix",
    "start": "npx serve .",
    "validate": "npm run lint && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zimixin/zimixin.github.io.git"
  },
  "keywords": [
    "rzd",
    "railway",
    "energy",
    "calculator",
    "train",
    "locomotive"
  ],
  "author": "RZD Calculator Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zimixin/zimixin.github.io/issues"
  },
  "homepage": "https://zimixin.github.io",
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^24.0.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "scripts/**/*.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "html"
    ]
  },
  "dependencies": {
    "@material/web": "^2.4.1",
    "playwright": "^1.58.2"
  },
  "directories": {
    "test": "tests"
  },
  "type": "commonjs"
}
